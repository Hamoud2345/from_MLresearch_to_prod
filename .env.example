# Copy to .env and adjust. All variables are optional (sensible defaults exist).

# Data source: "synthetic" (offline, default) or "entsoe" (real data, needs token)
PPF_DATA_SOURCE=synthetic
PPF_HISTORY_DAYS=730

# Model: "lightgbm" or "seasonal_naive"
PPF_MODEL_NAME=lightgbm

# MLflow
PPF_MLFLOW_TRACKING_URI=sqlite:///mlflow.db
PPF_MLFLOW_EXPERIMENT=day-ahead-price-forecast

# Drift alert threshold (Population Stability Index)
PPF_DRIFT_THRESHOLD=0.2

# Required only when PPF_DATA_SOURCE=entsoe
# ENTSOE_API_TOKEN=your-token-here
